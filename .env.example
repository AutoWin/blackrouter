BLACKROUTER_HOST=0.0.0.0
BLACKROUTER_PORT=20130
BLACKROUTER_DATA_DIR=/data
BLACKROUTER_DATABASE_URL=sqlite:///data/blackrouter.db
BLACKROUTER_COMPAT_9ROUTER_DB=false
BLACKROUTER_REQUIRE_API_KEY=false
BLACKROUTER_LOG_LEVEL=info

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_LINK_CODE_TTL_SECONDS=300
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=

# OAuth — Provider login via browser
# Register your own OAuth app or use the defaults below:
#   GitHub: https://github.com/settings/developers (Device Code Flow — no secret needed)
#   Google: https://console.cloud.google.com/apis/credentials (Web App, redirect: http://localhost:20130/api/oauth/google/callback)
#   Codex: https://platform.openai.com (OAuth App, redirect: http://localhost:20130/api/oauth/codex/callback)
# 
# OAuth credentials (create your own OAuth clients; do not commit real secrets):
# OAUTH_GITHUB_CLIENT_ID=Iv1.b507a08c87ecfe98
# OAUTH_GOOGLE_CLIENT_ID=<google-oauth-client-id>
# OAUTH_GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
# OAUTH_ANTIGRAVITY_CLIENT_ID=<google-oauth-client-id>
# OAUTH_ANTIGRAVITY_CLIENT_SECRET=<google-oauth-client-secret>
# OAUTH_GEMINI_CLI_CLIENT_ID=<google-oauth-client-id>
# OAUTH_GEMINI_CLI_CLIENT_SECRET=<google-oauth-client-secret>
# OAUTH_CODEX_CLIENT_ID=app_xxxxx
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_ANTIGRAVITY_CLIENT_ID=
OAUTH_ANTIGRAVITY_CLIENT_SECRET=
OAUTH_GEMINI_CLI_CLIENT_ID=
OAUTH_GEMINI_CLI_CLIENT_SECRET=
OAUTH_CODEX_CLIENT_ID=
BLACKROUTER_BASE_URL=http://localhost:20130

# Observability
# OpenTelemetry: set to enable distributed tracing (e.g. http://localhost:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=

# Logging
# RUST_LOG=info,blackrouter=debug
