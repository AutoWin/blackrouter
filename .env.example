BLACKROUTER_HOST=0.0.0.0
BLACKROUTER_PORT=20129
BLACKROUTER_DATA_DIR=/data
BLACKROUTER_DATABASE_URL=sqlite:///data/blackrouter.db
BLACKROUTER_COMPAT_9ROUTER_DB=false
BLACKROUTER_REQUIRE_API_KEY=false
BLACKROUTER_LOG_LEVEL=info

# Native macOS/local run example:
# BLACKROUTER_DATA_DIR=/Users/ccm/Documents/blackrouter/data
# BLACKROUTER_DATABASE_URL=sqlite:///Users/ccm/Documents/blackrouter/data/blackrouter.db

# Optional compatibility mode for a legacy 9Router DB:
# BLACKROUTER_COMPAT_9ROUTER_DB=true
# BLACKROUTER_DATA_DIR=/Users/ccm/.9router

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_LINK_CODE_TTL_SECONDS=300
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
